# Claude API key — required when ai_backend != "local_only" (bender_config.json).
# BenderPi is offline-first: an empty key here is a valid degraded state (AI
# turns fall back to error_fallback instead of a Claude response), but
# config.py's startup validate() will WARN loudly about it so the degradation
# isn't silent. Least-privilege: create a workspace-scoped API key
# (console.anthropic.com -> Settings -> API Keys, restrict to one workspace)
# with a monthly spend limit set on that workspace, rather than reusing an
# org-wide key. Not required if bender_config.json sets ai_backend: "local_only".
ANTHROPIC_API_KEY=

# Home Assistant — required for HA device control (HA_CONTROL intent) and
# weather briefings. Same warn-not-crash policy as above: empty is degraded,
# not fatal, but validate() warns on startup.
# Least-privilege: do NOT reuse your HA admin user's long-lived token. Create
# a dedicated restricted HA user instead (Settings -> People -> Add Person,
# uncheck "Administrator"), scope its entity access to just the light/switch/
# climate entities BenderPi should control (Settings -> People -> [user] ->
# per-entity permissions, or a restrictive area assignment), then mint the
# long-lived access token from *that* user's profile page
# (Profile -> Security -> Long-Lived Access Tokens). Verify the restricted
# token can still call the REST endpoints ha_control.py uses
# (GET /api/states, POST /api/services/climate/set_temperature, etc) against
# your actual HA instance before relying on it — HA's per-user entity
# permissions have edge cases.
HA_TOKEN=
HA_URL=http://192.168.68.125:8123
HA_WEATHER_ENTITY=weather.forecast_home

# Claude model for AI fallback (default: Haiku 4.5 — fast and cheap)
# Options: claude-haiku-4-5-20251001, claude-sonnet-4-6, claude-opus-4-6
BENDER_AI_MODEL=claude-haiku-4-5-20251001

# Web UI
# REQUIRED: bender-web fails closed and refuses to start if this is unset,
# empty, or left as a placeholder (CHANGE_ME / 2904). Set a real PIN.
# The UI verifies it once and then issues a signed ~12h token to the browser.
BENDER_WEB_PIN=CHANGE_ME
BENDER_WEB_PORT=8080
