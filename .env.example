# Claude API key — required for converse mode AI fallback
ANTHROPIC_API_KEY=

# Home Assistant — required for converse mode (weather + HA confirmations)
HA_TOKEN=
HA_URL=http://192.168.68.125:8123
HA_WEATHER_ENTITY=weather.forecast_home

# Claude model for AI fallback (default: Haiku 4.5 — fast and cheap)
# Options: claude-haiku-4-5-20251001, claude-sonnet-4-6, claude-opus-4-6
BENDER_AI_MODEL=claude-haiku-4-5-20251001

# Web UI
# REQUIRED: bender-web fails closed and refuses to start if this is unset,
# empty, or left as a placeholder (CHANGE_ME / 2904). Set a real PIN.
# The UI verifies it once and then issues a signed ~12h token to the browser.
BENDER_WEB_PIN=CHANGE_ME
BENDER_WEB_PORT=8080
