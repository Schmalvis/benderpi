# Wake word model (contains API key embedded, keep private)
*.ppn

# Credentials and secrets
*.key
*.token
config.local.*
.env

# Python
__pycache__/
*.pyc
*.pyo
.venv/
env/
venv/

# Runtime logs (JSON Lines — reviewed locally via review_log.py)
logs/*.jsonl

# Audio clips (large binaries, stored on rpi-share or rebuilt locally)
speech/wav/
speech/responses/**/*.wav

# TTS training artefacts (demucs venv, separated vocals, dataset)
tts/

# Piper inference binary (aarch64, ~51MB — download separately, see README)
piper/

# Trained voice model (ONNX, ~61MB — download from HF Hub, see README)
models/

# Cached briefing metadata (regenerated at runtime)
speech/responses/daily/

# Auto-generated status and metrics (regenerated after each deploy)
STATUS.md
logs/bender.log*
logs/metrics.jsonl*
.superpowers/

favourites.json
timers.json
.end_session
.session_active.json

# Svelte web app
web/node_modules/
web/dist/
