[Unit]
Description=BenderPi voice assistant (converse mode)
After=network-online.target sound.target
Wants=network-online.target
# Cap crash-restart thrash: after 5 restarts within 300s, systemd stops
# retrying and leaves the unit in "failed" state instead of looping forever
# (e.g. a bad deploy that passed the git_pull.sh gates but still crash-loops).
# Recovery: `sudo systemctl reset-failed bender-converse && sudo systemctl start bender-converse`.
StartLimitIntervalSec=300
StartLimitBurst=5

[Service]
Type=notify
NotifyAccess=main
WatchdogSec=120
Restart=on-failure
RestartSec=5
# If a mic read wedges and the process must be stopped, don't let it stick in
# "deactivating" forever: SIGKILL it after these timeouts. TimeoutStopSec covers
# a normal SIGTERM stop; TimeoutAbortSec covers the WatchdogSec=120 abort path.
TimeoutStopSec=20
TimeoutAbortSec=20
User=pi
WorkingDirectory=/home/pi/bender
EnvironmentFile=/home/pi/bender/.env
Environment=PYTHONUNBUFFERED=1
ExecStart=/home/pi/bender/venv/bin/python /home/pi/bender/scripts/wake_converse.py

[Install]
WantedBy=multi-user.target
